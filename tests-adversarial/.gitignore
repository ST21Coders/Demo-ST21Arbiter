# tests-adversarial/.gitignore — local override.
# Mirrors the "Adversarial harness" block in the root .gitignore so anyone
# working from inside this directory is still protected if they ever invoke
# git from here (or use a tool that scopes to the nearest .gitignore).
# Paths are relative to tests-adversarial/.

# Local secrets — never committed.
.env

# Python virtualenv — local-only.
.venv/

# Node modules — local-only, restored by `npm ci` / `npm install`.
node_modules/

# Per-persona Cognito storage states generated by the E2E global setup.
e2e/storage-states/

# Run artifacts (the harness writes here per the spec).
test-reports/

# Python / pytest / ruff caches and editable-install metadata — local-only.
.hypothesis/
.pytest_cache/
.ruff_cache/
*.egg-info/
__pycache__/
*.pyc

# npm lockfile drift between local installs is expected; commit on intent only.
# (package-lock.json is committed; the above directory entries are not.)

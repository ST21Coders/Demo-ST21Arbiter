# tests-adversarial/.env — local-only, gitignored.
# Copy to tests-adversarial/.env and fill in real values before running the harness.

# Required. Password for the four demo Cognito users (ciso_daiana@, soc_marcus@,
# grc_priya@, emp_sarah@). Harness fails fast if unset.
DEMO_PASSWORD=

# Required. Cognito User Pool ID for the deployed dev env (e.g. us-east-1_AbC123).
# Source: CFN export from the 03-identity stack, or the AWS console.
COGNITO_USER_POOL_ID=

# Required. Cognito app client ID (public SPA client, no secret).
# Source: same CFN export as the user pool id.
COGNITO_CLIENT_ID=

# Hard cap on estimated Bedrock spend per `test:all` run. Pre-flight refuses to
# start above this. Float, USD.
BEDROCK_COST_CAP_USD=1.00

# Deployed dev CloudFront. Override only for a staging env (which does not
# currently exist).
TARGET_BASE_URL=https://d5u0vv1zl3eqd.cloudfront.net/

# Optional API base. If unset the harness scrapes the SPA runtime config.
TARGET_API_URL=

# Optional Lambda Function URL for /chat. If unset the harness derives it from
# the SPA config alongside TARGET_API_URL.
TARGET_CHAT_URL=

# Optional Cognito Hosted UI domain (host only, no scheme, no trailing slash).
# Used by `e2e/tests/cognito-hosted-ui.spec.js::cognito-domain-reachable` to
# probe the Hosted UI's /login endpoint.
#
# Lookup: this is the value baked into `ui/src/config.js::COGNITO.domain`
# (line 23) from the Vite build-time env var `VITE_COGNITO_DOMAIN`. Example
# shape: `dev-arbiter.auth.us-east-1.amazoncognito.com`.
#
# Source of truth in the deployed env: CFN output `CognitoDomain` from the
# 03-identity stack, OR construct from the User Pool's domain prefix you
# picked: `<prefix>.auth.<region>.amazoncognito.com`.
#
# If unset, the spec falls back to scraping the deployed SPA's bundled JS
# (the value is inlined as a string literal at build time). If both the
# env var and the scrape fail, the test FAILS (not skips) so the smoke
# never silently misses regressions in CI.
COGNITO_DOMAIN=

# Hard-pinned by the project. Do not change.
AWS_REGION=us-east-1

# Where the run artifacts go. Always gitignored.
REPORT_DIR=test-reports/

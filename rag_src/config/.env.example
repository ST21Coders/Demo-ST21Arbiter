# Copy to config/.env (gitignored) or export in your shell before running notebooks.
# Any value here OVERRIDES config/settings.toml. This is how CI injects per-env config.

# --- Which environment's index names to use: dev | test | prod ---------------
ARBITER_ENV=dev

# --- AWS ----------------------------------------------------------------------
AWS_REGION=us-east-1
# Select the credentials/account for the ARBITER dev account (669810405473).
# AWS_PROFILE=st21arbiter-dev
# Safety guard: preflight FAILS if the resolved account != this id (see settings.toml [aws]).
# Blank in settings.toml by default (no guard); set to pin the account.
# ARBITER_EXPECTED_ACCOUNT_ID=669810405473

# --- Model swap (overrides [models] in settings.toml) -------------------------
# Default is Amazon Nova 2 Lite ONLY for now. Change here to swap the generation LLM.
# BEDROCK_GENERATION_MODEL_ID=us.amazon.nova-2-lite-v1:0
# BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- S3 Vectors (explicit names used by the ingest script + deployed agent) ---
# SALES_VECTOR_BUCKET=dev-st21arbiter-poc-sales-vectors
# SALES_VECTOR_INDEX=sales-facts

# --- Guardrails (optional) ----------------------------------------------------
# ARBITER_GUARDRAIL_ID=e0axl6y90il0
# ARBITER_GUARDRAIL_VERSION=1

        <mxCell id="nwxjK7dy7dN10PqU6JS9-62" parent="1" style="text;html=1;fontSize=11;fontStyle=0;align=left;spacingLeft=12;whiteSpace=wrap;fontColor=#1e293b;" value="Accessible pages:&#xa;✓ /              (Dashboard)&#xa;✓ /findings    (Conflicts/Findings)&#xa;✓ /heatmap    (System Map)&#xa;✓ /governance  (Compliance)&#xa;✓ /audit          (Audit Logs)&#xa;✓ /analyst      (Analyst Chat with session history)&#xa;&#xa;Blocked: ✗ /actions  ✗ /llm-control  ✗ /pipeline  ✗ /mcp-chat" vertex="1">

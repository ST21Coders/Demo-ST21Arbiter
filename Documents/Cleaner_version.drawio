        </mxCell>
        <mxCell id="nwxjK7dy7dN10PqU6JS9-19" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#01A88D;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;" value="SharePoint Specialist&#xa;Nova 2 Lite" vertex="1">
          <mxGeometry height="60" width="60" x="570" y="450" as="geometry" />
        </mxCell>
        <mxCell id="nwxjK7dy7dN10PqU6JS9-20" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#01A88D;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;" value="Zscaler Specialist&#xa;Nova 2 Lite" vertex="1">

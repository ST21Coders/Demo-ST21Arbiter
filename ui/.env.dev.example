# UI environment variables (dev).
# Copy to ui/.env.development (loaded by `npm run dev` / Vite dev server).
#
# Values reflect the CURRENT dev deployment in us-east-1. If you re-deploy
# 06-api or 03-identity, refresh by running:
#   aws cloudformation describe-stacks --stack-name dev-st21arbiter-poc-06-api \
#     --query 'Stacks[0].Outputs[?OutputKey==`UIEnvHints`].OutputValue' --output text
#
# Mapping:
#   VITE_API_URL           06-api      → ApiEndpoint      (all routes except /chat)
#   VITE_CHAT_URL          06-api      → ChatFunctionUrl  (Lambda Function URL — /chat only)
#   VITE_COGNITO_*         03-identity stack outputs
#
# NOTE: /chat hits the Function URL with AuthType=NONE (demo). The rest of
# the API still requires a Cognito JWT. The Function URL's CORS allow-list
# is set by 06-api's ChatFunctionUrlAllowedOrigins param (in Infra/params/dev.json) —
# http://localhost:5173 must be present for `npm run dev` to reach /chat.

VITE_API_URL=https://3en35lspt5.execute-api.us-east-1.amazonaws.com/dev
VITE_CHAT_URL=https://5yialez2n6chep4lv7opkja2gi0soxxd.lambda-url.us-east-1.on.aws/

VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_ZCn9RLdut
VITE_COGNITO_CLIENT_ID=7jj2t2ng0nta408g0h302f39ks
VITE_COGNITO_DOMAIN=poc-st21arbiter.auth.us-east-1.amazoncognito.com
# No CloudFront for `npm run dev` — use the Vite default origin (port 5173 is
# the only port currently in the Cognito Hosted UI callback whitelist).
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/

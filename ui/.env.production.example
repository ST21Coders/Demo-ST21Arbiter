# UI environment variables for the CloudFront-hosted production bundle.
#
# Infra/post_deploy_ui.py writes ui/.env.production from live CFN exports
# during deploy.sh. Vite reads it at build time (npm run build). You normally
# do NOT edit .env.production by hand — re-run deploy.sh (or post_deploy_ui.py)
# and the values regenerate from the live stack outputs.
#
# Source of truth for each value:
#   VITE_API_URL              06-api stack output `ApiEndpoint`
#   VITE_CHAT_URL             06-api stack output `ChatFunctionUrl` (Lambda Function URL — /chat bypasses APIGW 29s)
#   VITE_COGNITO_USER_POOL_ID 03-identity stack output `UserPoolId`
#   VITE_COGNITO_CLIENT_ID    03-identity stack output `UserPoolClientId`
#   VITE_COGNITO_DOMAIN       params/<env>.json::CognitoDomainPrefix + .auth.<region>.amazoncognito.com
#   VITE_COGNITO_REDIRECT_URI https://<CloudFrontDomain>/callback   (10-ui-hosting export)
#   VITE_COGNITO_LOGOUT_URI   https://<CloudFrontDomain>/
#
# LLM Control panel — mirrored from params/<env>.json (not CFN exports):
#   VITE_GUARDRAIL_NAME       derived as <env>-<project>-guardrail
#   VITE_GUARDRAIL_ID         params/<env>.json::GuardrailId
#   VITE_GUARDRAIL_VERSION    params/<env>.json::GuardrailVersion
#   VITE_GUARDRAIL_VERSIONS   params/<env>.json::GuardrailVersions (comma-separated switcher list)
#   VITE_*_MODEL_ID           params/<env>.json::{Master,Sharepoint,AwsConfig,Zscaler}ModelId

VITE_API_URL=https://abcd1234.execute-api.us-east-1.amazonaws.com/dev
VITE_CHAT_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.lambda-url.us-east-1.on.aws/

VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=poc-st21arbiter.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=https://d111111abcdef8.cloudfront.net/callback
VITE_COGNITO_LOGOUT_URI=https://d111111abcdef8.cloudfront.net/

VITE_GUARDRAIL_NAME=dev-st21arbiter-poc-guardrail
VITE_GUARDRAIL_ID=
VITE_GUARDRAIL_VERSION=DRAFT
VITE_GUARDRAIL_VERSIONS=DRAFT
VITE_MASTER_MODEL_ID=us.amazon.nova-2-lite-v1:0
VITE_SHAREPOINT_MODEL_ID=us.amazon.nova-2-lite-v1:0
VITE_AWSCONFIG_MODEL_ID=us.amazon.nova-2-lite-v1:0
VITE_ZSCALER_MODEL_ID=us.amazon.nova-2-lite-v1:0

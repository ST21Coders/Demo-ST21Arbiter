# Personal Claude Code memory — keep local, do not share
CLAUDE.local.md
.claude/settings.local.json

# Python venv created by scripts/ workflow (PEP 668 workaround)
scripts/.venv/
scripts/__pycache__/
**/__pycache__/
*.pyc

# SAM build cache
Infra/.aws-sam/

# Node dependencies / caches, at any depth (covers ui/, tests-adversarial/,
# and stray vitest caches at the repo root)
node_modules/

# UI build artifacts
ui/dist/

# Real per-env Vite values — generated by post_deploy_ui.py from CFN exports.
# Keep .env.*.example committed as templates; the real values stay local.
ui/.env
ui/.env.local
ui/.env.development
ui/.env.production
ui/.env.*.local

# Plan files / scratch
.claude/plans/
.aws-sam/
Documents/rag_enhancements_prompt.txt

# Pip wheels, egg-info
*.egg-info/
*.whl

# Coverage reports
ui/coverage/
.coverage
htmlcov/

# CloudFormation packaging artifacts
packaged-*.yaml
packaged-*.yml

# Adversarial harness (tests-adversarial/)
# Run artifacts live at the repo root; secrets, venv, and Playwright storage
# stay under tests-adversarial/.
test-reports/
tests-adversarial/.env
tests-adversarial/.venv/
tests-adversarial/e2e/storage-states/

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.lock
